# ==============================
# SaySavor Jarvis Environment
# Copy to .env and fill values
# ==============================

# --- Core services ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-or-anon-key
SUPABASE_ANON_KEY=your-supabase-anon-key
GOOGLE_API_KEY=your-google-api-key
GROQ_API_KEY=your-groq-api-key

# --- Bridge and backend ---
KAGGLE_URL=https://your-kaggle-or-ngrok-endpoint
BACKEND_URL=http://localhost:3000/get-jarvis-menu
AI_SECRET=replace-with-a-strong-shared-secret

# --- Security hardening ---
# Comma-separated origins allowed to call bridge_agent.py
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000,http://127.0.0.1:3000

# --- Runtime behavior ---
# Must match your backend/Supabase restaurant_id exactly
PARTNER_ID=9533b2b0-9cc3-4a6d-88d6-8cba406a9f33
JARVIS_USER_NAME=Guest
JARVIS_LANGUAGE=auto
JARVIS_TONE=friendly
JARVIS_VOICE_GENDER=male

# Optional: keep true only if you intentionally want old bridge prompt overlay
USE_LEGACY_BRIDGE_PROMPT=false
BRIDGE_FETCH_MENU_CONTEXT=true
MENU_FALLBACK_RESTAURANT_NAME=SaySavor
# Pipe-separated lines used only when backend menu fetch fails
MENU_FALLBACK_CONTEXT=Pizza Small: PKR 800|Pizza Medium: PKR 1200|Pizza Large: PKR 1800|Chicken Karahi: PKR 1500|Pasta: PKR 800

# Optional TTS language tag sent to Kaggle TTS endpoint
TTS_LANGUAGE_TAG=hi
MAX_TTS_CHARS=140

# --- Order workflow defaults (used by bridge CONFIRM_ORDER action) ---
DEFAULT_ITEM_PRICE=750
DEFAULT_TABLE_NO=1
DEFAULT_CUSTOMER_NAME=Guest
DEFAULT_CUSTOMER_ADDRESS=Dine-in
DEFAULT_PAYMENT_METHOD=CASH
